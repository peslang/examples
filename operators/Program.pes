// Операции.
// prespecs: arithmetic-operations, logical-and-boolean-operations, is, as, new-operator,
//            secure-access-operation, exclamation-mark-operation, double-question-mark-operator,
//            dot-operation, indexer-operator

метод ДемоАрифметика(): ничто
    пер a: Число = 10
    пер b: Число = 3
    Консоль.ЗаписатьСтроку("a+b=${a + b}, a**2=${a ** 2}, a%b=${a % b}")
    a = a + b
    Консоль.ЗаписатьСтроку("после a=a+b: ${a}")
;

метод ДемоЛогика(): ничто
    пер x: Булево = Истина
    пер y: Булево = Ложь
    Консоль.ЗаписатьСтроку("и=${x и y}, или=${x или y}, не=${не x}")
;

метод ДемоЭто(объект: Объект): ничто
    если объект это Число
        Консоль.ЗаписатьСтроку("это Число")
    иначе если объект это Строка
        Консоль.ЗаписатьСтроку("это Строка")
    ;
;

метод ДемоКак(объект: Объект): ничто
    пер n: Число = объект как Число
    Консоль.ЗаписатьСтроку("как Число: ${n + 1}")
;

метод ДемоNullable(): ничто
    пер м1: Массив<Число>?
    пер м2 = [1]
    м2.Добавить(2)
    // Операторы ?. / ! / ?? — см. prespecs; часть сценариев пока ограничена в codegen.
    Консоль.ЗаписатьСтроку("м1 null=${м1 == Неопределено}, м2[1]=${м2[1]}")
;

метод ДемоНовыйИДоступ(): ничто
    пер dt = новый DateTime(2025, 7, 9)
    пер year = dt.Year
    пер arr = [10]
    arr.Добавить(20)
    Консоль.ЗаписатьСтроку("новый: ${year}, arr[1]=${arr[1]}")
;

ДемоАрифметика()
ДемоЛогика()
ДемоЭто(42)
ДемоЭто("пес")
ДемоКак(42)
ДемоNullable()
ДемоНовыйИДоступ()
